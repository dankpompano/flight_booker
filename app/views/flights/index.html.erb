<h1>Flights#index</h1>
<p>Find me in app/views/flights/index.html.erb</p>

<p>
  <%# <%= form_with url: flight_path, method: :get, local: true do |form| %>
  <%= form_with model: @flights, method: :get do |form| %>
    <% form.label :arrival_ids, "Arrival Flights" %>
    <% form.collection_select :arrival_ids, Flight.all, :arrival_ids, :name, { prompt: 'Select an Arrival Flight' } %>

    <% form.label :departure_ids, "Departure Flights" %>
    <% form.collection_select :departure_ids, Flight.all, :departure_ids, :name, { prompt: 'Select a Departing Flight' } %>

    <% form.label :passengers, "Number of Passengers" %>
    <% form.select :passengers, options_for_select((1..4).to_a), { prompt: 'Number of passengers' } %>

    <% form.label :start, "Date" %>
    <% select_tag "flight_date", options_from_collection_for_select(@flight, 'id', 'name') %>

    <% form.submit "Select Flight" %>
  <% end %>
</p>
<button>Submit</button>
